# Copy file này thành .env để cấu hình runtime cho frontend.

# Dev (dùng Vite proxy trong vite.config.js):
# VITE_API_BASE_URL=/api
# VITE_BACKEND_BASE_URL=http://localhost:8080

# Ngrok (thay xxxx bằng domain ngrok của bạn):
# VITE_API_BASE_URL=https://xxxx.ngrok-free.app/api
# VITE_BACKEND_BASE_URL=https://xxxx.ngrok-free.app
